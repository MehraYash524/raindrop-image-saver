{
  "manifest_version": 2,
  "name": "Raindrop Image Saver",
  "version": "1.0.0",
  "description": "Save multiple images from any website to your Raindrop.io collections.",

  "icons": {
    "48": "assets/icons/icon48.png",
    "96": "assets/icons/icon96.png"
  },

  "browser_action": {
    "default_icon": { "48": "assets/icons/icon48.png" },
    "default_popup": "popup/popup.html",
    "default_title": "Save Images to Raindrop"
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "raindrop-image-saver@extension",
      "strict_min_version": "109.0"
    }
  }
}
